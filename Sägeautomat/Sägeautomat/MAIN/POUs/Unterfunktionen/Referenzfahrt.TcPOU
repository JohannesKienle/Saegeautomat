    <Action Name="Abschluss_active" Id="{73c6b22b-fa1f-4b49-969d-aaf633681f09}">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Action>
    <Action Name="Ende_exit" Id="{1672a3e4-67b0-4be6-bc60-cb8cfe2f5b24}">
      <Implementation>
        <ST><![CDATA[Hydraulik_EIN := FALSE;

busy := FALSE;
Referenz_Gefahren := TRUE;
Zyklus_Beendet := TRUE;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Hydraulik_An_active" Id="{7246612a-4487-4a08-a6b6-376711e720c2}">
      <Implementation>
        <ST><![CDATA[Hydraulik_EIN := TRUE;
Delay_2s(IN := TRUE, PT	:= Delay);
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Hydraulik_An_exit" Id="{31f64795-c125-4cb1-8e29-4526fbdc7e2f}">
      <Implementation>
        <ST><![CDATA[Delay_2s(IN := FALSE);

]]></ST>
      </Implementation>
    </Action>
    <Action Name="HydraulikEin_exit" Id="{f41e535b-b2cf-4132-942b-286e68a877c6}">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Action>
    <Action Name="Reset_entry" Id="{6012bee7-c849-43f8-aa0b-86f30e27c83a}">
      <Implementation>
        <ST><![CDATA[busy := FALSE;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Reset_exit" Id="{9ab3edb1-63b0-4841-8792-bcba287ba3d2}">
      <Implementation>
        <ST><![CDATA[busy := TRUE;
Referenz_Gefahren := FALSE;
Zyklus_Beendet := FALSE;

Saege_Heben := FALSE;
Stammklemmung_oben_Hoch := FALSE;
Stammklemmung_unten_Runter := FALSE;
Zufuehrer_Zurueck := FALSE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="SaegeHoch_active" Id="{fb0fbd67-0b64-45fc-91b0-7e6e3da61cdd}">
      <Implementation>
        <ST><![CDATA[IF NOT Endl_Saege_Oben THEN
	Saege_Heben := TRUE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="SaegeHoch_exit" Id="{8f298d13-0154-419e-a28e-4978d99f6581}">
      <Implementation>
        <ST><![CDATA[Saege_Heben := FALSE;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="Stammkl_Oben_Hoch_active" Id="{e80862e7-3f6b-4e1a-a4a7-4c9b44becc0a}">
      <Implementation>
        <ST><![CDATA[IF NOT Endl_Obere_Stammklemmung_Oben THEN
	Stammklemmung_oben_Hoch := TRUE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="Stammkl_Oben_Hoch_exit" Id="{2df2d016-c626-421e-95c9-201f1305f0a6}">
      <Implementation>
        <ST><![CDATA[Stammklemmung_oben_Hoch := FALSE;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="StammklUntenRunter_active" Id="{c2b9c445-1400-4bac-9d5f-bf96125c8de0}">
      <Implementation>
        <ST><![CDATA[IF NOT Endl_Untere_Stammklemmung_Unten THEN
	Stammklemmung_unten_Runter := TRUE;
END_IF]]></ST>
