  <POU Name="Referenzfahrt" Id="{9a52b441-711b-460e-af45-a6bf65171e00}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Referenzfahrt
VAR_INPUT
	//Taster
	Kein_Notaus : BOOL;
	Programm_Einzelsatz : BOOL;
	Zyklus_Start : BOOL;
	Zyklus_Stopp : BOOL;
	//Merker
	
	//Sensoren	
	Endl_Saege_Oben : BOOL;
	Endl_Obere_Stammklemmung_Oben : BOOL;
	Endl_Untere_Stammklemmung_Unten : BOOL;
	Endl_Zufuehrer_Hinten : BOOL;
	
END_VAR
VAR_OUTPUT
	Saege_Heben : BOOL;
	Stammklemmung_oben_Hoch : BOOL;
	Stammklemmung_unten_Runter : BOOL;
	Zufuehrer_Zurueck : BOOL;
END_VAR
VAR_IN_OUT
	//Merker
	busy : BOOL;
	Hydraulik_EIN : BOOL;
	Referenz_Gefahren : BOOL;
	Zyklus_Beendet : BOOL;
	
END_VAR
VAR
	Delay_2s : TON;
	Delay : TIME := T#2S;
	SFCInit : BOOL;
	SFCTip : BOOL;
	SFCTipMode : BOOL;
END_VAR

]]></Declaration>
