    </Action>
    <Action Name="StammklUntenRunter_exit" Id="{fb3dac32-aa8c-4383-ad20-6c543564ec2c}">
      <Implementation>
        <ST><![CDATA[Stammklemmung_unten_Runter := False;]]></ST>
      </Implementation>
    </Action>
    <Action Name="ZufuehrerZurueck_active" Id="{032bc72d-2cab-4a9c-bdb5-ddb2f3f995fd}">
      <Implementation>
        <ST><![CDATA[IF NOT Endl_Zufuehrer_Hinten THEN
