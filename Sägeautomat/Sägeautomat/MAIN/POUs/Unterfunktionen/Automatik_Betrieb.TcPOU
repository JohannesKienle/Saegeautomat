    <Action Name="Holz_Vor_active" Id="{ae9c850e-dfd9-47d0-b81d-0a71babc98c5}">
      <Implementation>
        <ST><![CDATA[IF NOT Vorposition_Zufuehrer AND NOT Endl_Zufuehrer_Vorne THEN
	QZufuehrer_Antrieb_vor := TRUE;
END_IF ]]></ST>
      </Implementation>
    </Action>
    <Action Name="Holz_Vor_exit" Id="{e0530356-532e-40fa-90f1-88a067669b06}">
