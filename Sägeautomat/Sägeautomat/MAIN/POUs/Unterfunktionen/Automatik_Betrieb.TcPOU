    </Action>
    <Action Name="Initialfahrt_active" Id="{3a592d82-235e-4e01-98bb-2a8a17d3bf23}">
      <Implementation>
        <ST><![CDATA[IF NOT Endl_Saege_Oben THEN
	QSaege_Heben := TRUE;
	warten := TRUE;
ELSE 
	QSaege_Heben := FALSE;
	warten := FALSE;
END_IF

IF NOT Endl_Obere_Stammklemmung_Oben AND NOT warten THEN
	QStammklemmung_Oben_Hoch := TRUE;
	warten := TRUE;
ELSE
	QStammklemmung_Oben_Hoch := FALSE;
	warten := FALSE;
END_IF

IF NOT Endl_Untere_Stammklemmung_Unten AND NOT warten THEN 
	QStammklemmung_Unten_Runter := TRUE;
	warten := TRUE;
ELSE 
	QStammklemmung_Unten_Runter := FALSE;
	warten := FALSE;
END_IF

IF NOT Endl_Zufuehrer_Hinten THEN
	QZufuehrer_Antrieb_Rueck := TRUE;
ELSE 
	QZufuehrer_Antrieb_Rueck := FALSE;
END_IF

]]></ST>
      </Implementation>
    </Action>
    <Action Name="Oben_Loesen_active" Id="{63a82339-152f-40b3-a547-93adeee09f71}">
