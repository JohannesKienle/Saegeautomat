]]></ST>
      </Implementation>
    </Action>
    <Action Name="Reset_active" Id="{655ea83a-bad9-42e6-8025-12d370509b5e}">
      <Implementation>
        <ST><![CDATA[//Hydraulik
QStammklemmung_Oben_Hoch := 
QStammklemmung_Oben_Runter := 
QStammklemmung_Unten_Hoch := 
QStammklemmung_Unten_Runter := 
QSaege_Senken := 
QSaege_Heben := 
//Ausgänge Schalten
QHydraulikpumpe_EIN := 
QZufuehrer_Antrieb_vor := 
QZufuehrer_Antrieb_Rueck := 
QSaege_Antrieb_Ein := 
QKettenschmierung_EIN := 
Warten_Auf_Weiterschalten :=
Hydraulik_EIN := 
Zyklus_Beendet := FALSE;
]]></ST>
      </Implementation>
    </Action>
