  <POU Name="Automatik_Betrieb" Id="{389c9999-3a59-4eae-a5d7-775f0832929f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK Automatik_Betrieb
VAR_INPUT
	Kein_Notaus : BOOL;
	Zyklus_Start : BOOL;
	Zyklus_Stopp : BOOL;
	SFCInit : BOOL;
	SFCTip : BOOL;
	SFCTipMode : BOOL;
	
	//Eingänge Sensorik
	//Zuführer
	Endl_Zufuehrer_Hinten : BOOL;
	Endl_Zufuehrer_Vorne : BOOL;
	Vorposition_Zufuehrer : BOOL;
	IOL_Schaltausg_Distanzsensor_Holzende : BOOL; //Über Schaltausgang oder IO-Link Analogdaten?
	IOL_DistanzSensor_Abst : UINT;
	//Stammklemmung Oben
	Endl_Obere_Stammklemmung_Oben : BOOL;
	Endl_Obere_Stammklemmung_Unten : BOOL;
	Endl_Tastschiene : BOOL;
	Schaltausg_Druckschalter_Obere_Klemmung : BOOL;
	//Stammklemmung Unten
	Endl_Untere_Stammklemmung_Oben : BOOL;
	Endl_Untere_Stammklemmung_Unten : BOOL;
	//Säge
	Endl_Saege_Oben : BOOL;
	Endl_Saege_Unten : BOOL;
	
END_VAR
VAR_OUTPUT
	Warten_Auf_Weiterschalten :BOOL;
	Warten_auf_Material : BOOL;
	//Hydraulik
	QStammklemmung_Oben_Hoch : BOOL;
	QStammklemmung_Oben_Runter : BOOL;
	QStammklemmung_Unten_Hoch : BOOL;
	QStammklemmung_Unten_Runter : BOOL;
	QSaege_Senken : BOOL;
	QSaege_Heben : BOOL;
	//Ausgänge Schalten
	QHydraulikpumpe_EIN : BOOL;
	QZufuehrer_Antrieb_vor : BOOL;
	QZufuehrer_Antrieb_Rueck : BOOL;
	QSaege_Antrieb_Ein : BOOL;
	QKettenschmierung_EIN : BOOL;
	
END_VAR
VAR_IN_OUT
	warten : BOOL;
	Hydraulik_EIN : BOOL;
	Zyklus_Beendet : BOOL;
END_VAR
VAR
	Holz_Fertig : BOOL;
	Holz_Geklemmt : BOOL;
END_VAR
]]></Declaration>
