      <LineId Id="32" Count="0" />
      <LineId Id="34" Count="6" />
      <LineId Id="33" Count="0" />
      <LineId Id="141" Count="1" />
      <LineId Id="147" Count="1" />
    </LineIds>
  </POU>
</TcPlcObject>